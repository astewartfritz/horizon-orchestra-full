+    def has_tool_budget(self) -> bool:
+        return self.tool_calls_remaining > 0
+
+    @property
+    def has_stt_budget(self) -> bool:
+        return self.stt_seconds_remaining > 0
+
+    @property
+    def has_tts_budget(self) -> bool:
+        return self.tts_characters_remaining > 0
