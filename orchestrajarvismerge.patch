+    TOOL_CALLS = "tool_calls"
+    SWARM_SPAWNS = "swarm_spawns"
+    STT_SECONDS = "stt_seconds"
+    TTS_CHARACTERS = "tts_characters"
+    MEMORY_ENTRIES = "memory_entries"
+    CODE_EXECUTIONS = "code_executions"
+    BROWSER_ACTIONS = "browser_actions"
+
+
