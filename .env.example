# Orchestra configuration
# Copy this file to .env and fill in your values.
# Generate secrets: python -c "import secrets; print(secrets.token_hex(32))"

# ── Deployment ──────────────────────────────────────────────
ORCHESTRA_ENV=development
# Set to "production" to enforce strict config validation.
# In production: JWT_SECRET, API_KEY_ENCRYPTION_KEY, and CORS_ORIGINS are REQUIRED.

# ── Server ──────────────────────────────────────────────────
ORCHESTRA_HOST=127.0.0.1
ORCHESTRA_PORT=8000
ORCHESTRA_LOG_LEVEL=info

# ── Security (REQUIRED in production) ───────────────────────
# JWT signing secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
# JWT_SECRET=<64-char-hex-string>

# Encryption key for stored API keys — generate same way
# API_KEY_ENCRYPTION_KEY=<64-char-hex-string>

# CORS allowed origins (comma-separated). Required in production.
# CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_CHAT_PER_MINUTE=20

# ── LLM Provider ────────────────────────────────────────────
ORCHESTRA_PROVIDER=ollama
ORCHESTRA_MODEL=nemotron-mini

# API keys for LLM providers (stored server-side after first /settings save)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_BASE_URL=http://192.168.1.100:11434/v1

# ── Database ─────────────────────────────────────────────────
# ORCHESTRA_DB=orchestra.db
# ORCHESTRA_BILLING_DB=orchestra_billing.db
# ORCHESTRA_LOGS_DB=~/.orchestra_logs.db

# ── Redis (optional — in-memory fallback used if not set) ────
# REDIS_URL=redis://localhost:6379/0

# ── Billing ──────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Observability ────────────────────────────────────────────
# SENTRY_DSN=https://...@sentry.io/...
# ORCHESTRA_JSON_LOGS=true

# OpenTelemetry
# OTEL_ENABLED=true
# OTEL_SERVICE_NAME=orchestra
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_EXPORTER_OTLP_INSECURE=true

# LangFuse LLM tracing
# LANGFUSE_HOST=https://cloud.langfuse.com
# LANGFUSE_PUBLIC_KEY=pk-...
# LANGFUSE_SECRET_KEY=sk-...

# ── Workspace ────────────────────────────────────────────────
ORCHESTRA_WORKSPACE=/workspace

# ── Misc ─────────────────────────────────────────────────────
EMBEDDING_PROVIDER=hash

# ── Docker Compose ───────────────────────────────────────────
# OLLAMA_PORT=11434

# ── Dual-plane architecture ───────────────────────────────────
# PLANE_AGENT_CONCURRENCY=10       # max parallel agent loops
# PLANE_AGENT_TIMEOUT_S=300        # hard timeout per agent run
# PLANE_API_TIMEOUT_S=30           # API request timeout
# PLANE_API_MAX_CONNECTIONS=1000
# PLANE_QUEUE_BACKEND=memory       # memory | redis | postgres
# PLANE_QUEUE_DSN=                 # redis:// or postgresql:// for queue
# PLANE_DB_DSN=                    # postgresql:// for async pool (falls back to DATABASE_URL)
# PLANE_DB_POOL_MIN=2
# PLANE_DB_POOL_MAX=10

# ── Cloud deployment (GCP Cloud Run) ─────────────────────────
# GOOGLE_CLOUD_PROJECT=your-project
# AWS_DEFAULT_REGION=us-east-1
# S3_WORKSPACE_BUCKET=

# ── Enterprise / SSO ─────────────────────────────────────────
# ORCHESTRA_OWNER_EMAIL=
# ORCHESTRA_OWNER_PASSWORD=
# SAML_IDP_METADATA_URL=
