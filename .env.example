# Horizon Orchestra — Environment Variables
# Copy this file to .env and fill in your keys.
# NEVER commit the .env file — it is in .gitignore.
# Owner: Ashton Fritz <ashtonfritz3@gmail.com>

# ── Model Providers (at least one required) ──────────────────
MOONSHOT_API_KEY=                  # Kimi K2.5 primary backbone
PERPLEXITY_API_KEY=                # Sonar retrieval (Arch B)
OPENROUTER_API_KEY=                # Claude Opus, Grok, etc.
OPENAI_API_KEY=                    # DALL-E, Whisper, TTS

# ── Gemma 4 / Google ─────────────────────────────────────────
GEMINI_API_KEY=
GOOGLE_API_KEY=

# ── Horizon Orchestra API ─────────────────────────────────────
JWT_SECRET=                        # Generate: openssl rand -hex 32
JWT_REFRESH_SECRET=                # Generate: openssl rand -hex 32
HORIZON_API_KEY=                   # Master API key for external clients

# ── Billing (Stripe) ─────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_TEAM_PRICE_ID=
STRIPE_MAX_PRICE_ID=price_max_250

# ── Cloud (AWS) ───────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_S3_BUCKET=
AWS_DYNAMODB_TABLE=

# ── Push Notifications (VAPID) ───────────────────────────────
VAPID_PRIVATE_KEY=                 # Generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:ashtonfritz3@gmail.com

# ── GPU Providers ────────────────────────────────────────────
LAMBDA_API_KEY=
COREWEAVE_API_KEY=
RUNPOD_API_KEY=
SPHERON_API_KEY=
HF_TOKEN=

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://orchestra:CHANGE_ME@localhost:5432/horizon
REDIS_URL=redis://localhost:6379

# ── Connectors ────────────────────────────────────────────────
GITHUB_TOKEN=
SLACK_TOKEN=
GMAIL_TOKEN=
NOTION_TOKEN=
MONDAY_API_KEY=
LINEAR_API_KEY=

# ── Terafab (Horizon custom compute) ─────────────────────────
TERAFAB_API_KEY=
TERAFAB_CLUSTER_URL=

# ── App ────────────────────────────────────────────────────────
ORCHESTRA_ENV=development          # development | staging | production
LOG_LEVEL=info
PORT=8000
NODE_PORT=3001
WORKERS=1
