# Orchestra configuration
# Copy to .env and fill in your values

# LLM Provider (ollama, openai, anthropic, vllm)
ORCHESTRA_PROVIDER=ollama

# Model name
ORCHESTRA_MODEL=nemotron-mini

# Server binding
ORCHESTRA_HOST=127.0.0.1
ORCHESTRA_PORT=8000

# Working directory (default: current dir)
ORCHESTRA_WORKSPACE=/workspace

# Log level (debug, info, warning, error)
ORCHESTRA_LOG_LEVEL=info

# ── API Keys ────────────────────────────────────────────────
# LLM_API_KEY=sk-...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Custom API base URL (e.g., for Ollama on a remote host)
# LLM_BASE_URL=http://192.168.1.100:11434/v1

# ── Observability ──────────────────────────────────────────
# OpenTelemetry (send metrics/traces/logs to Grafana, Datadog, etc.)
# OTEL_ENABLED=true
# OTEL_SERVICE_NAME=orchestra
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_EXPORTER_OTLP_INSECURE=true
# OTEL_METRICS_INTERVAL=30

# LangFuse LLM tracing
# LANGFUSE_HOST=https://cloud.langfuse.com
# LANGFUSE_PUBLIC_KEY=pk-...
# LANGFUSE_SECRET_KEY=sk-...

# Embedding provider (hash or sentence-transformers)
EMBEDDING_PROVIDER=hash

# ── Docker Compose ─────────────────────────────────────────
# These override the defaults in docker-compose.yml
# OLLAMA_PORT=11434
