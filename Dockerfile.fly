FROM python:3.13-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl ca-certificates build-essential && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install Python dependencies first (better layer caching)
COPY pyproject.toml README.md ./
RUN pip install --no-cache-dir \
    fastapi uvicorn[standard] httpx python-dotenv \
    anthropic openai \
    stripe \
    "passlib[bcrypt]" python-jose \
    prometheus-client \
    && pip install --no-cache-dir -e . 2>/dev/null || true

# Copy application source
COPY orchestra/ orchestra/
COPY orchestra_science/ orchestra_science/ 2>/dev/null || true
COPY entrypoint.py .
COPY run.py . 2>/dev/null || true

# Data directory (overridden by fly volume at /data)
RUN mkdir -p /data /data/sessions

ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1

EXPOSE 8000

HEALTHCHECK --interval=20s --timeout=5s --start-period=30s --retries=3 \
    CMD curl -sf http://localhost:8000/api/health || exit 1

ENTRYPOINT ["python", "/app/entrypoint.py"]
